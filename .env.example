# Base API host (no trailing slash)
SERVER_URL=https://prod-api.slasherplay.tv

# API path version segment, e.g. /api/v2/...
API_VERSION=v2

# Default query params sent with most requests
LANG_ID=1
DEVICE_ID=playwright-test-device
X_COUNTRY_CODE=AE

# Fixed/reusable QA login (confirmed by backend dev - always accepts this OTP).
# tests/global-setup.ts logs in fresh with these every run to mint AUTH_TOKEN.
TEST_ACCOUNT_EMAIL=testing@gmail.com
TEST_ACCOUNT_OTP=5057

# Only needed as a manual override; normally set automatically by global-setup.ts
AUTH_TOKEN=
